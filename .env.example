TRADEARENA_SECRET_KEY=change-me-in-production
DATABASE_URL=sqlite:///./tradearena.db
# For production (PostgreSQL):
# DATABASE_URL=postgresql://user:password@host:5432/tradearena
ANTHROPIC_API_KEY=sk-ant-...

# Production hardening (set these in deployment)
CORS_ORIGINS=*
# ENFORCE_HTTPS=1

# Discord Community Manager Bot
# DISCORD_BOT_TOKEN=your-bot-token-here

# Sentry error reporting (leave blank to disable — safe for dev/CI)
SENTRY_DSN=
# Environment tag sent to Sentry (default: development)
TRADEARENA_ENV=production
