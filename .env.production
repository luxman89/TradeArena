# TradeArena Production Environment
# Copy to .env and fill in real values before deploying.

# Required: your domain name (no https://)
DOMAIN=tradearena.example.com

# Required: generate with: python -c "import secrets; print(secrets.token_hex(32))"
TRADEARENA_SECRET_KEY=CHANGE_ME

# Required: generate a strong password for Postgres
POSTGRES_PASSWORD=CHANGE_ME

# Required: Anthropic API key for Haiku reasoning generation
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# DATABASE_URL is set automatically in docker-compose.prod.yml
# Do not set it here unless overriding the compose default.
