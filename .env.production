# TradeArena Production Environment
# Copy to .env and fill in real values before deploying.

# Required: your domain name (no https://)
DOMAIN=tradearena.duckdns.com

# Required: generate with: python -c "import secrets; print(secrets.token_hex(32))"
TRADEARENA_SECRET_KEY=CHANGE_ME

# Required: generate a strong password for Postgres
POSTGRES_PASSWORD=CHANGE_ME

# Required: Anthropic API key for Haiku reasoning generation
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# CORS: production domains only. Do NOT use "*" in production.
# Update to match your actual domain.
CORS_ORIGINS=https://tradearena.duckdns.org

# GitHub OAuth (required for login)
GITHUB_CLIENT_ID=CHANGE_ME
GITHUB_CLIENT_SECRET=CHANGE_ME
GITHUB_REDIRECT_URI=https://${DOMAIN}/auth/github/callback

# Twitter/X OAuth (optional — for X login)
TWITTER_CLIENT_ID=CHANGE_ME
TWITTER_CLIENT_SECRET=CHANGE_ME
TWITTER_REDIRECT_URI=https://${DOMAIN}/auth/twitter/callback

# HTTPS redirect (enable behind reverse proxy)
ENFORCE_HTTPS=1

# DATABASE_URL is set automatically in docker-compose.prod.yml
# Do not set it here unless overriding the compose default.
